{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Hold": {
    "DefaultDurationMinutes": 15
  },
  "Mongo": {
    "ConnectionString": "mongodb://127.0.0.1:27017",
    "DatabaseName": "inventory_hold"
  },
  "Redis": {
    "ConnectionString": "127.0.0.1:6379",
    "InventoryListTtlSeconds": 60,
    "HoldTtlSeconds": 120
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "inventory.events"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:5173"
  }
}
